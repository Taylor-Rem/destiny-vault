.manifest_cache.json
.weapon_defs_cache.json
__pycache__/
*.py[cod]

# ==== Virtual environments ====
venv/
.venv/
env/

# ==== OS cruft ====
.DS_Store
Thumbs.db

# ==== Personal god-roll rules (copy from rules.example.yaml) ====
rules.yaml
